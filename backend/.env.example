# BioVoice backend — environment variables
#
# Copy this file to `backend/.env` (gitignored) for local dev, or have your
# production secret manager populate it at deploy time. NEVER commit a real
# `.env` — the secret-scan pytest will fail CI if it appears under version
# control.
#
# Workflow recommendations (F2.4):
#   - Local dev: copy this file to .env and fill in placeholders.
#   - Cloud: store secrets in Doppler / 1Password / AWS Secrets Manager and
#     materialise them as env vars on the host before launching uvicorn.
#   - Containers: pass via `docker compose --env-file` or `--env`.
#   - K8s: bind to a Secret resource via `envFrom`.

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed browser origins (F2.2 / E2.2).
# For phone/iPad demos over Wi-Fi: add http://<your-LAN-IP>:5173 alongside
# http://localhost:5173.
# ---------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173

# ---------------------------------------------------------------------------
# Session lifecycle (F2.1) — rolling idle window for /auth/session and the
# refresh deadline.
# ---------------------------------------------------------------------------
SESSION_IDLE_SECONDS=1800

# ---------------------------------------------------------------------------
# /auth/login rate limiting (F2.2) — N failures in WINDOW seconds → lockout
# for LOCKOUT seconds.
# ---------------------------------------------------------------------------
LOGIN_RATE_MAX_ATTEMPTS=5
LOGIN_RATE_WINDOW_SECONDS=300
LOGIN_LOCKOUT_SECONDS=900

# ---------------------------------------------------------------------------
# Admin surface (F6) — gates /admin/* endpoints. Generate a high-entropy
# value (e.g. `python -c "import secrets; print(secrets.token_urlsafe(32))"`)
# and store it in your secret manager. Leave unset to disable the admin API
# entirely (default).
# ---------------------------------------------------------------------------
# BIOVOICE_ADMIN_API_KEY=replace-me-with-a-32+-byte-random-string

# ---------------------------------------------------------------------------
# Observability — log level (F7.2 will switch the format to structured JSON).
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# F7.1 will add DATABASE_URL for the SQLite → Postgres switch. Documented
# here so a single source of truth lists every recognised variable.
# Default (unset): sqlite at backend/data/biovoice.sqlite3.
# ---------------------------------------------------------------------------
# DATABASE_URL=postgres://user:password@host:5432/biovoice
